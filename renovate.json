{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "ignorePaths": ["**/node_modules/**", "**/.next/**"],
  "extends": [
    ":rebaseStalePrs",
    ":renovatePrefix",
    ":semanticCommits",
    ":timezone(Australia/Melbourne)",
    ":dependencyDashboard",
    ":pinDependencies",
    ":pinDevDependencies",
    "group:allNonMajor"
  ],
  "automerge": true,
  "mode": "full",
  "commitMessageAction": "",
  "labels": ["dependencies"],
  "dependencyDashboardOSVVulnerabilitySummary": "none",
  "prConcurrentLimit": 3,
  "prNotPendingHours": 1,
  "semanticCommitScope": "",
  "semanticCommitType": "deps",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "recreateWhen": "auto",
    "rebaseWhen": "behind-base-branch",
    "schedule": ["before 4am on monday"],
    "prBodyDefinitions": {
      "Change": "All locks refreshed"
    }
  },
  "packageRules": [
    {
      "extends": ["monorepo:nextjs"],
      "groupName": "nextjs monorepo",
      "matchUpdateTypes": ["digest", "patch", "minor", "major"]
    },
    {
      "description": "Node and types - LTS versions only",
      "matchPackageNames": ["node", "@types/node"],
      "groupName": "node and types",
      "matchManagers": ["mise", "npm", "pnpm"],
      "allowedVersions": "/^(20|22|24|26|28|30|32|34|36|38|40)\\./"
    }
  ]
}
